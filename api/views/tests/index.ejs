<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>

<div class="main-content">

  <div class="page-header">
    <div>
      <h4 class="page-title">كتالوج التحاليل</h4>
      <p class="text-muted small mb-0"><%= tests.length %> تحليل مسجل</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTestModal">
      <i class="bi bi-plus-lg me-1"></i>إضافة تحليل
    </button>
  </div>

  <!-- Search -->
  <form method="GET" action="/tests" class="card shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="row g-2 align-items-end">
        <div class="col-md-5">
          <input type="search" name="search" class="form-control form-control-sm"
                 placeholder="بحث في التحاليل..." value="<%= search %>">
        </div>
        <div class="col-md-3">
          <select name="category" class="form-select form-select-sm">
            <option value="">كل الفئات</option>
            <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-sm btn-primary">
            <i class="bi bi-search me-1"></i>بحث
          </button>
          <a href="/tests" class="btn btn-sm btn-outline-secondary ms-1">
            <i class="bi bi-x"></i>
          </a>
        </div>
      </div>
    </div>
  </form>

  <!-- Table -->
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>اسم التحليل</th>
            <th>الفئة</th>
            <th>السعر</th>
            <th>الحالة</th>
            <th>إجراءات</th>
          </tr>
        </thead>
        <tbody>
          <% tests.forEach((test, i) => { %>
          <tr>
            <td class="text-muted"><%= i + 1 %></td>
            <td class="fw-500"><%= test.name %></td>
            <td>
              <span class="badge bg-info-subtle text-info"><%= test.category %></span>
            </td>
            <td class="text-success fw-600">
              <%= parseFloat(test.price).toLocaleString('ar-EG') %> ج.م
            </td>
            <td>
              <% if (test.is_active) { %>
                <span class="badge bg-success-subtle text-success">فعال</span>
              <% } else { %>
                <span class="badge bg-secondary-subtle text-secondary">معطل</span>
              <% } %>
            </td>
            <td>
              <div class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="editTest(<%= JSON.stringify(test) %>)"
                        title="تعديل">
                  <i class="bi bi-pencil"></i>
                </button>
                <form action="/tests/<%= test.id %>?_method=DELETE" method="POST"
                      onsubmit="return confirm('حذف التحليل نهائياً؟')">
                  <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- Add Test Modal -->
<div class="modal fade" id="addTestModal" tabindex="-1">
  <div class="modal-dialog">
    <form action="/tests" method="POST" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">إضافة تحليل جديد</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-500">اسم التحليل <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="name" required placeholder="مثال: صورة دم كاملة CBC">
        </div>
        <div class="mb-3">
          <label class="form-label fw-500">الفئة <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="category" required
                 list="catList" placeholder="مثال: دم، سكر، كلى...">
          <datalist id="catList">
            <% categories.forEach(cat => { %>
            <option value="<%= cat %>">
            <% }) %>
          </datalist>
        </div>
        <div class="mb-0">
          <label class="form-label fw-500">السعر (ج.م) <span class="text-danger">*</span></label>
          <input type="number" class="form-control" name="price" required min="0" step="0.5" placeholder="0">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-plus me-1"></i>إضافة
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Test Modal -->
<div class="modal fade" id="editTestModal" tabindex="-1">
  <div class="modal-dialog">
    <form id="editTestForm" method="POST" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">تعديل التحليل</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-500">اسم التحليل</label>
          <input type="text" class="form-control" name="name" id="editName" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-500">الفئة</label>
          <input type="text" class="form-control" name="category" id="editCategory" required list="catList">
        </div>
        <div class="mb-3">
          <label class="form-label fw-500">السعر (ج.م)</label>
          <input type="number" class="form-control" name="price" id="editPrice" required min="0" step="0.5">
        </div>
        <div class="mb-0">
          <label class="form-label fw-500">الحالة</label>
          <select class="form-select" name="is_active" id="editActive">
            <option value="1">فعال</option>
            <option value="0">معطل</option>
          </select>
        </div>
        <input type="hidden" name="_method" value="PUT">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  function editTest(test) {
    document.getElementById('editTestForm').action = `/tests/${test.id}`;
    document.getElementById('editName').value     = test.name;
    document.getElementById('editCategory').value = test.category;
    document.getElementById('editPrice').value    = test.price;
    document.getElementById('editActive').value   = test.is_active ? '1' : '0';
    new bootstrap.Modal(document.getElementById('editTestModal')).show();
  }
</script>
